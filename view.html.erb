<!-- Debug Info (temporary) -->
<div style="background:#f8f9fa; padding:10px; margin-bottom:15px; border:1px solid #dee2e6;">
  Host variable from template: <%= host %><br>
  Port variable from template: <%= port %><br>
  Expected URL: /node/<%= host %>/<%= port %>/lab
</div>

<form action="/node/<%= host %>/<%= port %>/login" method="post" target="_blank">
  <input type="hidden" name="password" value="<%= password %>">
  <input type="hidden" name="next" value="/node/<%= host %>/<%= port %>/lab">
  <button class="btn btn-primary" type="submit">
    <i class="fa fa-registered"></i> Connect to Introduction to Shell app
  </button>
</form>
